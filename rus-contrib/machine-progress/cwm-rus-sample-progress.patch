+    /**
+     * Recursive count of files matching {@link #fileEndings} (traverse dirs; skip {@code ._*} junk).
+     *
+     * @param folder Root folder to scan
+     * @return Number of matching instrument files
+     */
+    protected int countMatchingInstrumentFiles (final File folder)
+    {
+        int count = 0;
+
+        final File [] children = folder.listFiles ();
+        if (children == null)
+            return 0;
+
+        for (final File f: children)
+        {
+            if (this.isCancelled ())
+                break;
+
+            if (f.isDirectory ())
+            {
+                count += this.countMatchingInstrumentFiles (f);
+                continue;
+            }
+
+            if (f.getName ().startsWith ("._"))
+                continue;
+
+            final String lower = f.getName ().toLowerCase (Locale.US);
+            for (final String ending: this.fileEndings)
+                if (lower.endsWith (ending))
+                {
+                    count++;
+                    break;
+                }
+        }
+
+        return count;
+    }
+
+
+    private int calcMachineProgressPercent ()
+    {
+        if (this.machineProgressTotal <= 0)
+            return this.machineProgressDone > 0 ? 100 : 0;
+        return (int) Math.min (100L, this.machineProgressDone * 100L / this.machineProgressTotal);
+    }
+
+
+    /** Pct at start of file {@code machineProgressDone} (0-based index): interpolation between milestones so a single giant .nki is not stuck at 0 %. */
+    private int calcMachineProgressPercentStartingCurrentFile ()
+    {
+        if (this.machineProgressTotal <= 0)
+            return this.machineProgressDone > 0 ? 100 : 0;
+
+        final int k = Math.max (0, this.machineProgressDone);
+        final int total = Math.max (1, this.machineProgressTotal);
+
+        final int lo = (int) (k * 100L / (long) total);
+        final int hi = Math.min (
+            100,
+            (int) ((k + 1L) * 100L / (long) total));
+        final int delta = hi - lo;
+        if (delta > 1)
+            return Math.min (
+                hi - 1,
+                Math.max (1, lo + Math.max (1, delta / 2)));
+        return Math.min (99, Math.max (1, lo + 1));
+    }
+
+
+    /** Pct immediately after completing the current file (same as legacy {@link #calcMachineProgressPercent}). */
+    private int calcMachineProgressPercentAfterFinishingCurrentFile ()
+    {
+        return this.calcMachineProgressPercent ();
+    }
+
+
+    /** Within-file pct while samples are loaded (unknown total -> asymptotic toward fileHi-1). */
+    private int calcMachineProgressPercentWithinCurrentFile ()
+    {
+        if (this.machineProgressTotal <= 0)
+            return this.machineProgressDone > 0 ? 100 : 0;
+
+        final int fileLo = (int) (this.machineProgressDone * 100L / (long) this.machineProgressTotal);
+        final int fileHi = Math.min (100, (int) ((this.machineProgressDone + 1L) * 100L / (long) this.machineProgressTotal));
+        if (fileHi <= fileLo + 1)
+            return Math.min (99, fileLo + 1);
+
+        final double span = (double) (fileHi - 1 - fileLo);
+        final double t = 1.0 - Math.exp (-this.machineProgressSamplesInFile / 25.0);
+        return fileLo + (int) Math.round (span * t);
+    }
